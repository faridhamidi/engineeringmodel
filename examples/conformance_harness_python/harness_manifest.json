{
  "manifest_version": 1,
  "rules": [
    {
      "id": "CORE.ARCH.001",
      "lifecycle": "active",
      "enforcement_mode": "zero_violation",
      "statement": "Decision modules do not import integration clients.",
      "rationale_ref": "../../core/FOUNDATION.md#1-name-the-boundaries",
      "owners": ["@faridhamidi"],
      "approval_control_ref": "../../CONTRIBUTING.md#conformance-rule-approval",
      "kind": "forbidden_import",
      "severity": "error",
      "scope": ["sample_project/decisions.py"],
      "config": {"forbidden_modules": ["sample_project.integrations"]},
      "positive_test": "tests.test_repository_invariants.RepositoryInvariantTests.test_core_arch_001",
      "refutation_test": "tests.test_checker_refutations.CheckerRefutationTests.test_core_arch_001"
    },
    {
      "id": "CORE.ARCH.002",
      "lifecycle": "active",
      "enforcement_mode": "ratchet",
      "known_violations": ["sample_project/known_constructor_site.py"],
      "statement": "External clients have designated construction owners.",
      "rationale_ref": "../../core/FOUNDATION.md#enforcement",
      "owners": ["@faridhamidi"],
      "approval_control_ref": "../../CONTRIBUTING.md#conformance-rule-approval",
      "kind": "exclusive_constructor_owner",
      "severity": "error",
      "scope": ["sample_project"],
      "config": {"constructor": "VendorClient", "allowed_owners": ["sample_project/integrations.py"]},
      "positive_test": "tests.test_repository_invariants.RepositoryInvariantTests.test_core_arch_002",
      "refutation_test": "tests.test_checker_refutations.CheckerRefutationTests.test_core_arch_002"
    },
    {
      "id": "CORE.CONTEXT.001",
      "lifecycle": "active",
      "enforcement_mode": "zero_violation",
      "statement": "Service operations carry a stable operation identifier.",
      "rationale_ref": "../../core/FOUNDATION.md#3-preserve-execution-context-across-every-hop",
      "owners": ["@faridhamidi"],
      "approval_control_ref": "../../CONTRIBUTING.md#conformance-rule-approval",
      "kind": "required_context_parameter",
      "severity": "error",
      "scope": ["sample_project/service.py"],
      "config": {"function": "run_operation", "parameter": "operation_id"},
      "positive_test": "tests.test_repository_invariants.RepositoryInvariantTests.test_core_context_001",
      "refutation_test": "tests.test_checker_refutations.CheckerRefutationTests.test_core_context_001"
    }
  ],
  "audit": {
    "report_path_default": "artifacts/conformance-audit.md",
    "checks": [
      {"name": "manifest", "command": ["{python}", "check_manifest.py"]},
      {"name": "contracts", "command": ["{python}", "check_contracts.py"]},
      {"name": "tests", "command": ["{python}", "-m", "unittest", "discover", "-s", "tests", "-v"]}
    ]
  }
}
